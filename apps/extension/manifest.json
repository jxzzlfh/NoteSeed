{
  "manifest_version": 3,
  "name": "NoteSeed",
  "version": "1.0.0",
  "description": "Seed the web into your second brain.",
  "permissions": ["activeTab", "sidePanel", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/service-worker/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/side-panel/index.html"
  },
  "options_page": "src/options/index.html",
  "action": {
    "default_title": "NoteSeed"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content-script/index.ts"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
