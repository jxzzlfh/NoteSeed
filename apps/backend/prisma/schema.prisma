generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String           @id @default(uuid())
  email       String           @unique
  createdAt   DateTime         @default(now())
  settings    UserSettings?
  credentials UserCredential[]
  saveLogs    SaveLog[]
}

model UserSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  defaultTemplate   String   @default("auto")
  defaultTarget     String   @default("memos")
  outputLanguage    String   @default("zh-CN")
  retentionLevel    String   @default("standard")
  enabledSkillsJson Json     @default("{\"contextualizer\":true,\"tagger\":true,\"styleMatcher\":false,\"chronicle\":true}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserCredential {
  id            String   @id @default(uuid())
  userId        String
  target        String
  encryptedData String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, target])
}

model SaveLog {
  id           String   @id @default(uuid())
  userId       String
  cardId       String
  target       String
  status       String
  responseJson Json?
  errorMessage String?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
