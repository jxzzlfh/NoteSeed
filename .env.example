# ======================
# NoteSeed Environment Variables
# ======================

# Database (Prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/noteseed

# Credential Encryption (AES-256, for storing Memos tokens etc.)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
CREDENTIAL_ENCRYPTION_KEY=<32-byte-base64-string>

# Feishu (optional, for Feishu adapter)
# FEISHU_APP_ID=<your-feishu-app-id>
# FEISHU_APP_SECRET=<your-feishu-app-secret>

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
